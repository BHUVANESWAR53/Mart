from fastapi import FastAPI, UploadFile, File, Form
from fastapi.responses import HTMLResponse

app = FastAPI()

@app.get("/", response_class=HTMLResponse)
async def home():
    return """
<!DOCTYPE html>
<html>
<head>
<title>AI Assistant</title>
<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,sans-serif;
}

body{
    background:#f5f7fb;
}

.container{
    display:flex;
    height:100vh;
}

.sidebar{
    width:260px;
    background:white;
    border-right:1px solid #ddd;
    padding:20px;
    display:flex;
    flex-direction:column;
}

.logo{
    font-size:28px;
    font-weight:bold;
    margin-bottom:30px;
}

.new-chat{
    background:#2351ff;
    color:white;
    border:none;
    padding:15px;
    border-radius:12px;
    font-size:18px;
    cursor:pointer;
    margin-bottom:20px;
}

.history{
    background:#f1f3f7;
    border:none;
    padding:15px;
    border-radius:12px;
    text-align:left;
    font-size:18px;
    cursor:pointer;
}

.profile{
    margin-top:auto;
    padding:15px;
    border-top:1px solid #ddd;
    font-size:18px;
}

.main{
    flex:1;
    display:flex;
    justify-content:center;
    align-items:center;
}

.content{
    width:700px;
}

.content h1{
    text-align:center;
    margin-bottom:30px;
}

.upload-box{
    background:white;
    border:1px solid #ddd;
    border-radius:15px;
    padding:20px;
    margin-bottom:20px;
}

textarea{
    width:100%;
    height:180px;
    border:1px solid #ddd;
    border-radius:15px;
    padding:15px;
    resize:none;
    font-size:16px;
}

.send{
    margin-top:15px;
    float:right;
    width:50px;
    height:50px;
    border:none;
    border-radius:50%;
    background:#2351ff;
    color:white;
    font-size:20px;
    cursor:pointer;
}
</style>
</head>
<body>

<div class="container">

    <div class="sidebar">
        <div class="logo">AI Assistant</div>

        <button class="new-chat">+ New Chat</button>

        <button class="history">🕒 History</button>

        <div class="profile">
            👤 Profile
        </div>
    </div>

    <div class="main">

        <div class="content">

            <h1>Hi, how can I assist?</h1>

            <form action="/upload" method="post" enctype="multipart/form-data">

                <div class="upload-box">
                    <input type="file" name="file">
                </div>

                <textarea
                    name="text"
                    placeholder="Enter your text here..."
                ></textarea>

                <button class="send" type="submit">
                    ➤
                </button>

            </form>

        </div>

    </div>

</div>

</body>
</html>
"""

@app.post("/upload")
async def upload(
    file: UploadFile = File(...),
    text: str = Form(...)
):
    return {
        "filename": file.filename,
        "message": text
    }

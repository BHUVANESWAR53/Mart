<!DOCTYPE html>
<html>
<head>
<style>
body{
    margin:0;
    background:#f5f6fa;
    font-family:Arial,sans-serif;
}

.sidebar{
    width:260px;
    height:95vh;
    margin:15px;
    background:white;
    border-radius:20px;
    box-shadow:0 5px 20px rgba(0,0,0,.08);
    display:flex;
    flex-direction:column;
}

.logo{
    padding:25px;
    font-size:30px;
    font-weight:bold;
    color:#0b5d46;
    border-bottom:1px solid #eee;
}

.menu{
    flex:1;
    padding:15px;
}

.menu-item{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:14px 15px;
    margin-bottom:8px;
    border-radius:12px;
    cursor:pointer;
    transition:.3s;
}

.menu-item:hover{
    background:#f4f4f4;
}

.left{
    display:flex;
    gap:12px;
    align-items:center;
}

.icon{
    width:20px;
}

.profile-card{
    margin:15px;
    background:#fff7ef;
    border-radius:15px;
    padding:12px;
    display:flex;
    align-items:center;
    gap:10px;
    border:1px solid #ffe3bf;
}

.profile-img{
    width:45px;
    height:45px;
    border-radius:50%;
    background:#ff9800;
}

.profile-info{
    flex:1;
}

.profile-name{
    font-size:14px;
    font-weight:bold;
}

.profile-email{
    font-size:12px;
    color:gray;
}
</style>
</head>
<body>

<div class="sidebar">

    <div class="logo">
        AI Assistant
    </div>

    <div class="menu">

        <div class="menu-item">
            <div class="left">
                📊 <span>Dashboard</span>
            </div>
        </div>

        <div class="menu-item">
            <div class="left">
                📦 <span>Orders</span>
            </div>
            <span>+</span>
        </div>

        <div class="menu-item">
            <div class="left">
                🛒 <span>E-Commerce</span>
            </div>
            <span>+</span>
        </div>

        <div class="menu-item">
            <div class="left">
                💳 <span>Transactions</span>
            </div>
        </div>

        <div class="menu-item">
            <div class="left">
                📈 <span>Reports</span>
            </div>
        </div>

        <div class="menu-item">
            <div class="left">
                👤 <span>Profile</span>
            </div>
        </div>

    </div>

    <div class="profile-card">
        <div class="profile-img"></div>

        <div class="profile-info">
            <div class="profile-name">
                Bhuvaneshwar
            </div>
            <div class="profile-email">
                user@example.com
            </div>
        </div>
    </div>

</div>

</body>
</html>
